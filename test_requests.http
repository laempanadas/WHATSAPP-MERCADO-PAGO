@baseUrl = http://localhost:8080

###
# 🏥 Health Check - Verificar se servidor está vivo
GET {{baseUrl}}/health


###
# ✅ Webhook Validação GET (Meta envia para validar servidor)
GET {{baseUrl}}/webhook/whatsapp?hub.mode=subscribe&hub.verify_token=seu_token_aqui&hub.challenge=test_challenge_123


###
# 💬 Webhook POST - Mensagem de Texto "oi"
POST {{baseUrl}}/webhook/whatsapp
Content-Type: application/json

{
  "object": "whatsapp_business_account",
  "entry": [
    {
      "id": "123456",
      "changes": [
        {
          "value": {
            "messaging_product": "whatsapp",
            "messages": [
              {
                "from": "5511997088839",
                "id": "wamid.123456",
                "timestamp": "1699564000",
                "text": {
                  "body": "oi"
                },
                "type": "text"
              }
            ],
            "contacts": [
              {
                "profile": {
                  "name": "João"
                },
                "wa_id": "5511997088839"
              }
            ]
          }
        }
      ]
    }
  ]
}


