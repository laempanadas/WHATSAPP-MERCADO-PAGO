# Variáveis de Ambiente - Cloud Run

# Mercado Pago (obrigatório)
MP_ACCESS_TOKEN=seu_access_token_do_mercado_pago

# WhatsApp Business API (obrigatório)
WA_TOKEN=seu_token_do_whatsapp
PHONE_NUMBER_ID=seu_phone_number_id
VERIFY_TOKEN=seu_token_de_verificacao

# URL base da aplicação (obrigatório)
BASE_URL=https://whatsappmercadopago-1052937983065.southamerica-east1.run.app

# Número do dono para receber notificações de pedido pago (opcional)
# Formato: código do país + DDD + número (sem espaços, sem símbolos)
# Exemplo: 5511959480047 (Brasil, São Paulo, celular)
ADMIN_PHONE=5511959480047

# Habilita a configuração automática de catálogo/carrinho no startup (opcional)
COMMERCE_SETTINGS_ENABLED=true
